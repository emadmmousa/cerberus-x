# Cerberus-X environment configuration.
#
# Copy this file to `.env` at the repository root (git-ignored) and fill in
# strong, locally-generated secrets. Never commit real credentials.
#
#   cp .env.example .env
#
# Generate strong random secrets, e.g.:
#   openssl rand -hex 24
#   # or
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Startup (from repository root):
#   docker compose up -d
#   # or, using the docker/ compose file (loads secrets from ../.env via env_file):
#   docker compose -f docker/docker-compose.yml up -d
#
# Metasploit runs a DB-connected msfconsole that loads MessagePack `msgrpc`
# (not standalone msfrpcd). The healthcheck authenticates, calls
# core.version, and requires db.status to report driver=postgresql with a
# connected database name. Startup hard-fails if db_connect / provisioning
# does not succeed.

# --- PostgreSQL (internal only, not published to the host) ---
POSTGRES_USER=msf
# REQUIRED: no default is provided. Generate a strong value.
POSTGRES_PASSWORD=
POSTGRES_DB=msf

# --- Metasploit RPC (internal only, not published to the host) ---
MSF_RPC_USER=msf
# REQUIRED: no default is provided. Generate a strong value.
MSF_RPC_PASSWORD=
# Wired by docker-compose / entrypoint (normally leave defaults):
# MSF_RPC_HOST=metasploit
# MSF_RPC_PORT=55553
# MSF_RPC_SSL=false
# MSF_RPC_VERIFY_SSL=false
# MSF_DB_HOST=postgres
# MSF_DB_PORT=5432

# --- Oxylabs residential proxy (workers + UI settings; never commit real values) ---
# Mission Control "Proxy settings" overwrites these keys on save (Redis + this file +
# in-cluster Secret/ConfigMap when available).
OXYLABS_PROXY_HOST=pr.oxylabs.io
OXYLABS_PROXY_PORT=7777
OXYLABS_PROXY_PROTOCOL=http
OXYLABS_PROXY_USERNAME=
OXYLABS_PROXY_PASSWORD=
CERBERUS_LOCAL_PROXY_HOST=127.0.0.1
CERBERUS_LOCAL_PROXY_PORT=18080
# Optional: path the orchestrator writes when saving proxy settings from the UI.
# CERBERUS_ENV_FILE=/app/.env

# --- MCP (Model Context Protocol) ---
CERBERUS_MCP_ENABLED=true
# REQUIRED for /mcp when enabled. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CERBERUS_MCP_API_KEY=
CERBERUS_MCP_RATE_LIMIT_PER_MIN=30

# --- AI orchestration (unrestricted by default for authorized engagements) ---
CERBERUS_AI_REQUIRE_CONFIRM=false
CERBERUS_LLM_UNRESTRICTED=true
CERBERUS_LLM_TEMPERATURE=0.9
CERBERUS_LLM_TOP_P=0.95
# Base model pulled by compose; custom persona model created from docker/ollama/Modelfile
CERBERUS_LLM_BASE_MODEL=llama3.2
# Recommended with docker compose `ollama` service (in-cluster):
CERBERUS_LLM_BASE_URL=http://ollama:11434/v1
CERBERUS_LLM_API_KEY=ollama
CERBERUS_LLM_MODEL=cerberus-x
# --- SQL injection (sqlmap strategy) ---
# Intensity: off|low|medium|high|aggressive (default follows evasion level, else aggressive)
CERBERUS_SQLI_INTENSITY=aggressive
# Optional OOB DNS catcher domain for sqlmap --dns-domain
# CERBERUS_SQLMAP_DNS_DOMAIN=exfil.yourdomain.com
# Optional second-order injection landing URL
# CERBERUS_SQLMAP_SECOND_ORDER=https://target/profile
# CERBERUS_SQLMAP_DUMP_ALL=false
# CERBERUS_SQLMAP_OS_SHELL=false
# Host-only Ollama (no compose service): http://host.docker.internal:11434/v1

# --- Security / auth / vault (optional) ---
SECRET_KEY=change-me
CERBERUS_WAF_ENABLED=true
CERBERUS_RATE_LIMIT_ENABLED=true
CERBERUS_ADMIN_USER=admin
CERBERUS_ADMIN_PASSWORD=
# Enable with: docker compose --profile vault up -d vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=
CERBERUS_VAULT_AUTO_ROTATE=false
CERBERUS_AUTO_SCALE=false
# Server-side sessions (Flask-Session → Redis). Secure cookie flag for HTTPS.
CERBERUS_SESSION_SECURE=false
# Daily ML + learning tick (also toggleable in Admin → Ops)
CERBERUS_AUTO_TRAIN=false
CERBERUS_AUTO_TRAIN_HOUR=3
CERBERUS_LEARNING_TICK=false
CERBERUS_TRAIN_GPU=false
# Require authorized_targets.json when true (default: auto-allow + audit)
CERBERUS_REQUIRE_AUTHZ=false
AUTHORIZED_TARGETS_FILE=/app/authorized_targets.json
# Metasploit reverse-payload callback (required for reverse shells from remote targets).
# Use a host/IP the *target* can reach (VPN/public IP). Inside Docker Compose labs,
# try your LAN IP or host.docker.internal. Leave blank to auto-detect outbound IP,
# or set CERBERUS_PAYLOAD_PREFER=bind to skip reverse connect-back.
# CERBERUS_LHOST=
# CERBERUS_LPORT_START=4444
# CERBERUS_PAYLOAD_PREFER=reverse
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LDAP_SERVER=
LDAP_BASE_DN=
ALERT_WEBHOOK=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
AUDIT_S3_BUCKET=
